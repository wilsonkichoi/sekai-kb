---
import { getCollection, render } from 'astro:content';
import ArticleTemplate from '../../templates/article.template.astro';
import placeConfig from '../../../place.config';
import { getGitInfo } from '../../utils/git-info';
// Prebuilt by scripts/core/build-related-tagoverlap.mjs: { "cat/slug": ["cat/slug", ...] }.
import relatedData from '../../data/related/en.json';

export async function getStaticPaths() {
  const articles = await getCollection('en');
  const validSlugs = new Set(
    placeConfig.categories.map((c) => c.slug),
  );

  const parsed = articles
    .map((article) => {
      const parts = article.id.split('/');
      const category = parts.length > 1 ? parts[0] : 'uncategorized';
      const slug = parts.length > 1 ? parts.slice(1).join('/') : article.id;
      const cleanSlug = slug.replace(/\.md$/, '');
      return { params: { category, slug: cleanSlug }, props: { article }, data: article.data };
    })
    .filter((entry) => validSlugs.has(entry.params.category));

  // Lookup "cat/slug" → { title, category, slug } to resolve related ids to link data.
  const byKey = new Map(
    parsed.map((e) => [
      `${e.params.category}/${e.params.slug}`,
      { title: e.data.title, category: e.params.category, slug: e.params.slug },
    ]),
  );
  const related: Record<string, string[]> = relatedData;

  return parsed.map((entry) => {
    const key = `${entry.params.category}/${entry.params.slug}`;
    const relatedArticles = (related[key] ?? [])
      .map((id) => byKey.get(id))
      .filter((a): a is { title: string; category: string; slug: string } => Boolean(a));
    return {
      params: entry.params,
      props: {
        article: entry.props.article,
        relatedArticles,
        latestArticles: parsed
          .filter((e) => !(e.params.category === entry.params.category && e.params.slug === entry.params.slug))
          .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
          .slice(0, 4)
          .map((e) => ({
            title: e.data.title,
            description: e.data.description,
            category: e.params.category,
            slug: e.params.slug,
            date: e.data.date,
          })),
      },
    };
  });
}

const { category, slug } = Astro.params;
const { article, latestArticles, relatedArticles } = Astro.props;
const { Content, headings } = await render(article);

const wordCount = (article.body ?? '').replace(/\s+/g, ' ').trim().split(' ').length;
const readingTime = Math.max(1, Math.round(wordCount / 200));
const gitInfo = getGitInfo(category!, slug!);
---

<ArticleTemplate
  title={article.data.title}
  description={article.data.description}
  headings={headings}
  frontmatter={article.data}
  category={category!}
  slug={slug!}
  readingTime={readingTime}
  latestArticles={latestArticles}
  relatedArticles={relatedArticles}
  contributors={gitInfo.contributors}
  commitHash={gitInfo.commitHash}
>
  <Content />
</ArticleTemplate>
