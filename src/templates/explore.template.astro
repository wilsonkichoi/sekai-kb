---
/**
 * /explore — the searcher's entry point (the homepage serves readers; /explore
 * serves people who came to find something). Search-first: a prominent box that
 * opens the global search modal (single source of truth in Layout.astro — no
 * duplicated search infrastructure), plus the category grid and a latest strip.
 *
 * Genericized from the fork: the fork's version depended on GA analytics +
 * dashboard-vitals JSON + a 12-category i18n bundle, none of which exist in the
 * rebuild. Data flows from the `en` content collection + place.config.ts.
 */
import Layout from '../layouts/Layout.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import { getCollection } from 'astro:content';
import { getCategoryConfigs } from '../utils/categoryConfig';
import placeConfig from '../../place.config';

const { features } = placeConfig;
const cats = getCategoryConfigs();
const validSlugs = new Set(placeConfig.categories.map((c) => c.slug));

const entries = await getCollection('en');
const articles = entries
  .map((entry) => {
    const parts = entry.id.split('/');
    const category = parts.length > 1 ? parts[0] : 'uncategorized';
    const slug = (parts.length > 1 ? parts.slice(1).join('/') : entry.id).replace(
      /\.md$/,
      '',
    );
    return {
      title: entry.data.title,
      category,
      slug,
      date: entry.data.date ? new Date(entry.data.date) : new Date(0),
    };
  })
  .filter((a) => validSlugs.has(a.category));

const totalArticles = articles.length;
const latest = [...articles]
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 8);

const dayShort = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---

<Layout
  title="Explore"
  description={`Search across all articles and browse every topic on ${placeConfig.place.name}.`}
>
  <section class="mx-auto max-w-[var(--container-wide)] px-6 pt-12 pb-4 text-center max-[768px]:px-4 max-[768px]:pt-10">
    <h1 class="text-[clamp(2rem,5vw,3rem)] font-black -tracking-[0.02em] text-[#0e3a5c]">
      Explore
    </h1>
    <p class="mx-auto mt-3 max-w-[600px] text-[1.05rem] leading-[1.6] text-[#64748b] max-[480px]:text-[0.95rem]">
      Full-text search across every article, or browse by topic.
      <span class="whitespace-nowrap"><strong>{totalArticles}</strong> articles.</span>
    </p>
  </section>

  <!-- Search + random -->
  <section class="relative mb-10 px-4">
    <div class="mx-auto flex max-w-[820px] gap-3 rounded-[18px] border border-[#e2e8f0] bg-white p-4 shadow-[0_18px_50px_rgba(15,23,42,0.12)] max-[600px]:flex-col">
      <button
        type="button"
        id="explore-search-trigger"
        class="group flex flex-1 items-center gap-3 rounded-xl border-2 border-[#cbd5e1] bg-[#f8fafc] px-5 py-[0.95rem] text-left transition-all hover:border-[#10b981] hover:bg-white focus:border-[#10b981] focus:outline-none"
        aria-label="Search all articles"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#64748b"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="flex-shrink-0 transition-colors group-hover:stroke-[#10b981]"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span class="flex-1 text-[1rem] font-medium text-[#94a3b8] max-[480px]:text-[0.9rem]">
          Search across all articles…
        </span>
        <kbd class="hidden flex-shrink-0 rounded border border-[#e2e8f0] bg-white px-2 py-[0.15rem] font-mono text-[0.75rem] font-semibold text-[#64748b] sm:inline-block">
          /
        </kbd>
      </button>
      <button
        type="button"
        id="explore-random-btn"
        class="group flex items-center justify-center gap-2 rounded-xl border-2 border-[#f59e0b] bg-[linear-gradient(135deg,#f59e0b,#d97706)] px-5 py-[0.95rem] font-bold text-white transition-all hover:-translate-y-px active:translate-y-0 max-[600px]:py-3"
        aria-label="Random article"
      >
        <span class="text-[1.4rem] leading-none transition-transform group-hover:rotate-[20deg]">🎲</span>
        <span class="text-[0.95rem]">Surprise me</span>
      </button>
    </div>
  </section>

  <!-- Categories -->
  <section class="my-14 max-[768px]:my-10">
    <div class="mb-6 px-4 text-center">
      <h2 class="text-[2rem] font-black -tracking-[0.02em] text-[#1a1a2e] max-[768px]:text-[1.6rem]">
        Browse by Topic
      </h2>
    </div>
    <CategoryGrid />
  </section>

  <!-- Latest strip -->
  {
    latest.length > 0 && (
      <section class="mx-auto my-14 max-w-[860px] px-8 max-[768px]:my-10 max-[768px]:px-4">
        <div class="mb-6 flex items-end justify-between gap-4">
          <h2 class="text-[2rem] font-black -tracking-[0.02em] text-[#1a1a2e] max-[768px]:text-[1.6rem]">
            Latest
          </h2>
          <a
            href="/latest"
            class="flex-shrink-0 whitespace-nowrap text-[0.88rem] font-semibold text-[#10b981] no-underline hover:underline"
          >
            See all
          </a>
        </div>
        <div class="flex flex-col gap-1">
          {latest.map((a) => {
            const cfg = cats[a.category] || ({} as (typeof cats)[string]);
            return (
              <a
                href={`/${a.category}/${encodeURIComponent(a.slug)}`}
                class="group flex items-center gap-3 rounded-lg border border-transparent px-3 py-2.5 no-underline transition-all hover:border-[#e2e8f0] hover:bg-[#f8fafc]"
              >
                <span
                  class="flex-shrink-0 rounded-full px-[0.5rem] py-[0.15rem] text-[0.68rem] font-semibold"
                  style={`color:${cfg.color || '#64748b'}; background:${cfg.colorLight || '#f1f5f9'};`}
                >
                  {cfg.icon} {cfg.name}
                </span>
                <span class="min-w-0 flex-1 truncate text-[0.98rem] font-semibold text-[#1a1a2e] group-hover:text-[#065f46]">
                  {a.title}
                </span>
                <span class="flex-shrink-0 font-mono text-[0.76rem] tabular-nums text-[#94a3b8]">
                  {dayShort(a.date)}
                </span>
              </a>
            );
          })}
        </div>
      </section>
    )
  }

  <!-- More ways to explore -->
  {
    (features.graph || features.map) && (
      <section class="mx-auto my-16 max-w-[var(--container-wide)] px-8 max-[768px]:my-10 max-[768px]:px-4">
        <div class="mb-8 text-center">
          <h2 class="text-[1.6rem] font-black -tracking-[0.02em] text-[#1a1a2e] max-[768px]:text-[1.35rem]">
            More ways to explore
          </h2>
        </div>
        <div class="grid grid-cols-2 gap-5 max-[900px]:grid-cols-1 max-[900px]:gap-4">
          {features.graph && (
            <a
              href="/graph"
              class="group flex items-start gap-4 rounded-2xl border border-[#e2e8f0] bg-white p-6 no-underline transition-all hover:-translate-y-1 hover:border-[#7c3aed]"
            >
              <span class="flex-shrink-0 text-[2rem]">🕸️</span>
              <div class="flex-1">
                <h3 class="mb-1 text-[1.05rem] font-bold text-[#1a1a2e] group-hover:text-[#7c3aed]">
                  Knowledge Graph
                </h3>
                <p class="text-[0.88rem] leading-[1.55] text-[#64748b]">
                  See how every topic connects.
                </p>
              </div>
            </a>
          )}
          {features.map && (
            <a
              href="/map"
              class="group flex items-start gap-4 rounded-2xl border border-[#e2e8f0] bg-white p-6 no-underline transition-all hover:-translate-y-1 hover:border-[#10b981]"
            >
              <span class="flex-shrink-0 text-[2rem]">🗺️</span>
              <div class="flex-1">
                <h3 class="mb-1 text-[1.05rem] font-bold text-[#1a1a2e] group-hover:text-[#065f46]">
                  Map
                </h3>
                <p class="text-[0.88rem] leading-[1.55] text-[#64748b]">
                  Browse everything by location.
                </p>
              </div>
            </a>
          )}
        </div>
      </section>
    )
  }
</Layout>

<script is:inline>
  // Search trigger → open the global modal (Layout.astro owns it) and focus input.
  function _openSearchModal(prefill) {
    var modal = document.getElementById('search-modal');
    var input = document.getElementById('search-input');
    if (!modal || !input) return;
    modal.classList.add('open');
    if (typeof prefill === 'string' && prefill.length > 0) {
      input.value = prefill;
      input.dispatchEvent(new Event('input', { bubbles: true }));
    }
    setTimeout(function () {
      input.focus();
    }, 100);
  }

  document.addEventListener('DOMContentLoaded', function () {
    var trigger = document.getElementById('explore-search-trigger');
    if (trigger) {
      trigger.addEventListener('click', function () {
        _openSearchModal();
      });
    }

    // Random article — pull the topics index and navigate to a random entry.
    var randomBtn = document.getElementById('explore-random-btn');
    if (randomBtn) {
      randomBtn.addEventListener('click', async function () {
        randomBtn.style.pointerEvents = 'none';
        randomBtn.style.opacity = '0.7';
        try {
          var res = await fetch('/kb/topics.json');
          if (!res.ok) throw new Error('topics fetch failed');
          var topics = await res.json();
          if (!topics.length) throw new Error('empty');
          var pick = topics[Math.floor(Math.random() * topics.length)];
          window.location.href = pick.url;
        } catch (e) {
          randomBtn.style.pointerEvents = '';
          randomBtn.style.opacity = '';
        }
      });
    }
  });
</script>
