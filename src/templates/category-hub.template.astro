---
/**
 * category-hub.template.astro — category hub page layout.
 *
 * Extracted from the v1 fork. Genericized: single language, categories from
 * place.config.ts via categoryConfig.
 */
import { marked } from 'marked';
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';
import { categoryList, getCategoryConfig, getCategoryConfigs } from '../utils/categoryConfig';
import placeConfig from '../../place.config';
import type { Lang } from '../config/languages';

interface ArticleSummary {
  slug: string;
  title: string;
  description: string;
  readingTime: number | null;
  date: string | null;
  featured: boolean;
  tags: string[];
  image: string | null;
  subcategory: string;
  footnotes: number;
}

interface Props {
  category: string;
  hubContent: string;
  topPicks: ArticleSummary[];
  articles: ArticleSummary[];
}

const { category, hubContent, articles, topPicks } = Astro.props;

const lang: Lang = 'en';
const t = useTranslations(lang);

const allConfigs = getCategoryConfigs();
const categoryInfo = getCategoryConfig(category) ?? {
  name: category,
  description: '',
  icon: '',
  color: '#475569',
  colorLight: '#47556920',
};

// Compute unique tags for filter
const allTagsSet = new Set<string>();
articles.forEach((a) => {
  if (a.tags) a.tags.forEach((tag) => allTagsSet.add(tag));
});

function resolveWikilinks(md: string, currentCategory: string) {
  if (!md) return md;

  function resolveOne(target: string, display?: string, bold = false) {
    const label = display || target;
    if (target.startsWith('_')) {
      const catName = target
        .replace(/^_/, '')
        .replace(/ Hub$/, '')
        .toLowerCase();
      return bold
        ? `<a class="topic-pill" href="/${catName}"><strong>${label}</strong></a>`
        : `<a class="topic-pill" href="/${catName}">${label}</a>`;
    }
    const matchArticle = articles.find(
      (a) =>
        a.title === target ||
        a.slug === target ||
        a.slug === encodeURIComponent(target),
    );
    if (matchArticle) {
      const url = `/${currentCategory}/${matchArticle.slug}`;
      return bold
        ? `<a class="topic-pill" href="${url}"><strong>${label}</strong></a>`
        : `<a class="topic-pill" href="${url}">${label}</a>`;
    }
    return bold ? `**${label}**` : label;
  }

  md = md.replace(
    /\*\*\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]\*\*/g,
    (_, target, display) => resolveOne(target, display, true),
  );
  md = md.replace(/\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g, (_, target, display) =>
    resolveOne(target, display),
  );
  return md;
}

const resolvedContent = hubContent
  ? resolveWikilinks(hubContent, category)
  : '';

const articleUrlSet = new Set(
  articles.map((a) => `/${category}/${a.slug}`),
);
const categoryKeys = categoryList;

const hubRenderer = new marked.Renderer();
hubRenderer.image = ({ href, title, text }) => {
  const titleAttr = title ? ` title="${title}"` : '';
  const altText = text || '';
  return `<img src="${href}" alt="${altText}"${titleAttr} loading="lazy" onerror="this.onerror=null;this.classList.add('img-broken')" />`;
};
hubRenderer.link = ({ href, title, text }) => {
  const titleAttr = title ? ` title="${title}"` : '';
  const h = href || '';
  const isArticleLink = articleUrlSet.has(decodeURIComponent(h));
  const isCategoryLink = categoryKeys.some(
    (k) => h === `/${k}` || h === `/${k}/`,
  );
  if (isArticleLink || isCategoryLink) {
    return `<a class="topic-pill" href="${h}"${titleAttr}>${text}</a>`;
  }
  return `<a href="${h}"${titleAttr}>${text}</a>`;
};
const rawHubHtml = resolvedContent
  ? marked.parse(resolvedContent, { renderer: hubRenderer, breaks: true })
  : '';

function enrichBlockquotes(html: string): string {
  if (!html) return html;
  const calloutMap: Record<string, string> = {
    '\u{1F4DD}': 'callout-note',
    '⚠️': 'callout-warning',
    '\u{1F4A1}': 'callout-tip',
    '\u{1F4CA}': 'callout-data',
  };
  return html.replace(
    /<blockquote>([\s\S]*?)<\/blockquote>/g,
    (match, inner) => {
      if (inner.includes('✦')) {
        return `<blockquote class="pull-quote">${inner}</blockquote>`;
      }
      for (const [emoji, cls] of Object.entries(calloutMap)) {
        if (inner.includes(emoji) && inner.includes('<strong>')) {
          return `<blockquote class="${cls}">${inner}</blockquote>`;
        }
      }
      return match;
    },
  );
}
const hubHtml = enrichBlockquotes(rawHubHtml as string);

let hubHook = '';
let hubFull = hubHtml;
if (hubHtml) {
  let stripped = (hubHtml as string)
    .replace(/^(\s*<h[12][^>]*>[\s\S]*?<\/h[12]>\s*)+/i, '')
    .trim();
  let cutIndex = -1;
  let pCount = 0;
  const pCloseRegex = /<\/p>/gi;
  let match;
  while ((match = pCloseRegex.exec(stripped)) !== null) {
    pCount++;
    if (pCount === 3) {
      cutIndex = match.index + match[0].length;
      break;
    }
  }
  if (cutIndex > 0 && cutIndex < stripped.length * 0.7) {
    hubHook = stripped.slice(0, cutIndex);
    hubFull = hubHtml;
  }
}

// Group articles by subcategory
const subcategoryGroups: { name: string; articles: ArticleSummary[] }[] = [];
const subcatMap = new Map<string, ArticleSummary[]>();
for (const article of articles) {
  const sub = article.subcategory || 'Other';
  if (!subcatMap.has(sub)) subcatMap.set(sub, []);
  subcatMap.get(sub)!.push(article);
}
for (const [name, arts] of [...subcatMap.entries()].sort((a, b) => {
  if (a[0] === 'Other') return 1;
  if (b[0] === 'Other') return -1;
  return a[0].localeCompare(b[0]);
})) {
  subcategoryGroups.push({ name, articles: arts });
}

// Other categories for sidebar cross-nav
const otherCategories = categoryList
  .filter((cat) => cat !== category)
  .map((cat) => ({
    key: cat,
    ...allConfigs[cat],
  }));
---

<Layout
  lang={lang}
  title={`${categoryInfo.name} - ${placeConfig.place.domain}`}
  description={categoryInfo.description}
  category={categoryInfo.name}
  readerSettings
>
  <main class="category-page">
    <div
      class="bg-[var(--categoryColorLight)] pb-5 pt-3"
      style={`border-bottom: 2px solid ${categoryInfo.color};`}
    >
      <div class="mx-auto max-w-[var(--container-wide)] px-8 max-[768px]:px-4">
        <nav
          class="mb-1 flex items-center gap-2 text-[0.9rem] [&>a:hover]:underline [&>a]:font-medium [&>a]:no-underline"
        >
          <a
            href="/"
            style={`color: ${categoryInfo.color};`}>{t('article.home')}</a
          >
          <span class="text-[#9ca3af]">&rsaquo;</span>
          <span class="font-semibold text-[#6b7280]">{categoryInfo.name}</span>
        </nav>
        <div class="flex flex-wrap items-baseline gap-2">
          <span class="text-[1.5rem]">{categoryInfo.icon}</span>
          <h1
            class="m-0 text-[1.5rem] font-extrabold"
            style={`color: ${categoryInfo.color}`}
          >
            {categoryInfo.name}
          </h1>
          <span class="font-light text-[#94a3b8] max-[768px]:hidden">&middot;</span>
          <span
            class="max-w-[50%] truncate text-[0.88rem] text-[#64748b] max-[768px]:hidden"
            >{categoryInfo.description}</span
          >
          <span
            class="ml-auto rounded-[12px] bg-[#f1f5f9] px-2 py-[0.15rem] text-[0.78rem] text-[#94a3b8]"
            >{
              t('category.articleCount').replace('{n}', String(articles.length))
            }</span
          >
        </div>
        {
          hubHook && (
            <div class="mt-3 max-w-[800px] text-[0.92rem] leading-[1.75] text-[#475569] max-[768px]:text-[0.85rem]">
              <div class="header-hook-prose" set:html={hubHook} />
              <a
                href="#hub-essay"
                class="mt-2 inline-block text-[0.82rem] font-semibold text-[var(--categoryColor)] no-underline transition-all duration-150 hover:underline"
              >
                {t('category.readGuide')}
              </a>
            </div>
          )
        }
      </div>
    </div>

    <div
      class="mx-auto max-w-[var(--container-wide)] px-8 py-8 max-[768px]:px-4 max-[768px]:py-4"
    >
      {
        articles.length > 0 ? (
          <div class="mt-4 flex items-start gap-8 max-[768px]:flex-col max-[768px]:gap-0">
            <aside class="sticky top-[72px] w-[180px] flex-shrink-0 self-start max-[768px]:static max-[768px]:w-full max-[768px]:max-h-none max-[768px]:overflow-visible">
              {subcategoryGroups.length > 1 && (
                <nav class="flex flex-col gap-1 max-[768px]:flex-row max-[768px]:flex-wrap max-[768px]:gap-[0.3rem] max-[768px]:border-b max-[768px]:border-[#e2e8f0] max-[768px]:pb-4 max-[768px]:mb-4">
                  <span class="mb-[0.3rem] border-b border-[#e2e8f0] px-2 pb-[0.4rem] text-[0.7rem] font-bold uppercase tracking-[0.1em] text-[#94a3b8] max-[768px]:hidden">
                    {t('category.topic')}
                  </span>
                  {subcategoryGroups.map((group) => (
                    <a
                      href={`#sub-${group.name}`}
                      data-sub-link={group.name}
                      class="subcat-nav-link flex items-center justify-between rounded border-l-2 border-transparent px-2 py-[0.35rem] text-[0.82rem] text-[#475569] no-underline transition-all duration-150 hover:bg-[rgba(45,80,22,0.06)] hover:text-[var(--categoryColor,#1e3a5f)] max-[768px]:rounded-2xl max-[768px]:border max-[768px]:border-[#e2e8f0] max-[768px]:bg-[#f8fafc] max-[768px]:px-[0.6rem] max-[768px]:py-1 max-[768px]:text-[0.78rem]"
                    >
                      {group.name}
                      <span class="min-w-[1.2rem] rounded-lg bg-[#f1f5f9] px-[0.35rem] py-[0.1rem] text-center text-[0.7rem] text-[#94a3b8]">
                        {group.articles.length}
                      </span>
                    </a>
                  ))}
                </nav>
              )}

              <div class="my-3 h-px bg-[#e2e8f0] max-[768px]:hidden" />
              <nav class="flex flex-col gap-1 max-[768px]:hidden">
                <span class="mb-[0.3rem] border-b border-[#e2e8f0] px-2 pb-[0.4rem] text-[0.7rem] font-bold uppercase tracking-[0.1em] text-[#94a3b8]">
                  {t('category.otherTopics')}
                </span>
                {otherCategories.map((cat) => (
                  <a
                    href={`/${cat.key}`}
                    class="flex items-center justify-between rounded px-2 py-[0.35rem] text-[0.78rem] text-[#475569] no-underline opacity-75 transition-all duration-150 hover:bg-[rgba(45,80,22,0.06)] hover:text-[var(--categoryColor,#1e3a5f)] hover:opacity-100"
                  >
                    <span>
                      {cat.icon} {cat.name}
                    </span>
                  </a>
                ))}
              </nav>
            </aside>

            <div class="min-w-0 flex-1">
              {topPicks && topPicks.length > 0 && (
                <div class="mb-4 flex flex-wrap items-center gap-2 border-b border-[#e2e8f0] pb-3 max-[768px]:flex-nowrap max-[768px]:overflow-x-auto max-[768px]:pb-2 max-[768px]:[-webkit-overflow-scrolling:touch]">
                  <span class="flex-shrink-0 text-[0.72rem] font-bold uppercase tracking-[0.08em] text-[var(--categoryColor)]">
                    {t('category.featured')}
                  </span>
                  {topPicks.slice(0, 3).map((article) => (
                    <a
                      href={`/${category}/${encodeURIComponent(article.slug)}`}
                      class="whitespace-nowrap rounded-2xl border border-transparent bg-[var(--categoryColorLight)] px-[0.6rem] py-[0.2rem] text-[0.82rem] font-semibold text-[var(--categoryColor)] no-underline transition-all duration-150 hover:border-[var(--categoryColor)] hover:bg-white"
                    >
                      &starf; {article.title}
                    </a>
                  ))}
                </div>
              )}

              <div class="articles-main min-w-0 flex-1" id="articlesGrid">
                <div class="mb-4">
                  <input
                    type="text"
                    class="w-full max-w-[320px] rounded-md border border-[#e2e8f0] px-3 py-[0.45rem] text-[0.85rem] outline-none transition-colors duration-200 focus:border-[var(--categoryColor,#1e3a5f)] focus:shadow-[0_0_0_2px_rgba(45,80,22,0.08)]"
                    id="articleFilter"
                    placeholder={t('category.searchPlaceholder')}
                    autocomplete="off"
                  />
                </div>

                {subcategoryGroups.map((group) => (
                  <div class="subcategory-section" id={`sub-${group.name}`}>
                    {subcategoryGroups.length > 1 && (
                      <h3 class="mb-2 mt-6 flex items-center gap-2 border-b-2 border-[var(--categoryColor,#e2e8f0)] pb-[0.4rem] text-[1rem] font-bold text-[#334155] [.subcategory-section:first-child_&]:mt-0">
                        {group.name}
                        <span class="text-[0.72rem] font-normal text-[#94a3b8]">
                          {group.articles.length}
                        </span>
                      </h3>
                    )}
                    <div class="flex flex-col">
                      {group.articles.map((article) => (
                        <a
                          href={`/${category}/${encodeURIComponent(article.slug)}`}
                          class={`article-row ${article.featured ? 'is-featured' : ''}`}
                          data-title={article.title}
                          data-date={article.date || ''}
                          data-reading={article.readingTime || 0}
                          data-featured={article.featured ? '1' : '0'}
                          data-tags={JSON.stringify(article.tags || [])}
                          data-subcategory={article.subcategory || ''}
                        >
                          <div class="row-main">
                            <div class="row-title-line">
                              {article.featured && (
                                <span class="row-star">&starf;</span>
                              )}
                              <h3 class="row-title">{article.title}</h3>
                            </div>
                            {article.description && (
                              <p class="row-desc">
                                {article.description.length > 120
                                  ? article.description.slice(0, 117) + '...'
                                  : article.description}
                              </p>
                            )}
                          </div>
                          <div class="row-meta">
                            {(article.footnotes || 0) > 0 && (
                              <span class="row-fn">
                                {t('category.citations').replace(
                                  '{n}',
                                  String(article.footnotes),
                                )}
                              </span>
                            )}
                            {article.readingTime && (
                              <span class="row-time">
                                {article.readingTime} min
                              </span>
                            )}
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}

                <div
                  class="hidden p-8 text-center text-[#94a3b8]"
                  id="noResults"
                >
                  <p>{t('category.noResults')}</p>
                </div>
              </div>

              {hubHtml && (
                <section
                  class="my-8 mb-12 rounded-2xl border border-[#e2e8f0] bg-white p-10 shadow-[0_1px_3px_rgba(0,0,0,0.04)]"
                  id="hub-essay"
                >
                  <h2 class="mb-2 mt-12 border-t-2 border-[#e2e8f0] pt-8 text-[1.15rem] font-bold text-[#334155]">
                    {categoryInfo.icon} {t('hub.essay.heading')}
                  </h2>
                  <div class="hub-prose" set:html={hubHtml} />
                </section>
              )}
            </div>
          </div>
        ) : (
          <section class="px-8 py-16 text-center max-[768px]:px-4">
            <div class="mx-auto max-w-[500px]">
              <div class="mb-8 text-[5rem] opacity-70">{categoryInfo.icon}</div>
              <h2 class="mb-4 text-[2.5rem] font-bold text-[#1f2937]">
                {t('hub.empty.title')}
              </h2>
              <p class="mb-6 text-[1.1rem] leading-[1.6] text-[#6b7280]">
                {t('hub.empty.description')}
              </p>
              <p class="!mb-12 text-[1.1rem] font-medium italic text-[var(--categoryColor)]">
                {t('hub.empty.future')}
                {categoryInfo.description}
              </p>
              <div class="flex flex-wrap justify-center gap-4 max-[768px]:flex-col max-[768px]:items-center">
                <a
                  href="/"
                  class="inline-flex items-center gap-2 rounded-xl bg-[var(--categoryColor)] px-8 py-4 font-semibold text-white no-underline transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_16px_rgba(0,0,0,0.2)]"
                >
                  {t('article.backToHome')}
                </a>
              </div>
            </div>
          </section>
        )
      }
    </div>
  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.getElementById('articlesGrid');
    const noResults = document.getElementById('noResults');
    const filterInput = document.getElementById(
      'articleFilter',
    ) as HTMLInputElement;
    if (!grid) return;

    const cards = Array.from(
      grid.querySelectorAll('.article-row'),
    ) as HTMLElement[];
    const subcategorySections = Array.from(
      grid.querySelectorAll('.subcategory-section'),
    ) as HTMLElement[];

    function applyFilters() {
      const query = filterInput?.value.toLowerCase() || '';
      let visible = 0;
      cards.forEach((card) => {
        const title = (card.dataset.title || '').toLowerCase();
        const tags: string[] = JSON.parse(card.dataset.tags || '[]');
        const matchQuery = !query || title.includes(query) || tags.some(t => t.toLowerCase().includes(query));
        const show = matchQuery;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      subcategorySections.forEach((section) => {
        const sectionCards = section.querySelectorAll(
          '.article-row',
        ) as NodeListOf<HTMLElement>;
        const anyVisible = Array.from(sectionCards).some(
          (c) => c.style.display !== 'none',
        );
        section.style.display = anyVisible ? '' : 'none';
      });
      if (noResults) {
        noResults.classList.toggle('hidden', visible !== 0);
      }
    }

    filterInput?.addEventListener('input', () => {
      applyFilters();
    });
  });
</script>

<style
  define:vars={{
    categoryColor: categoryInfo.color,
    categoryColorLight: categoryInfo.colorLight,
  }}
>
  .subcat-nav-link.active {
    background-color: rgba(45, 80, 22, 0.08);
    border-left-color: var(--categoryColor, #1e3a5f);
    color: var(--categoryColor, #1e3a5f);
    font-weight: 600;
  }

  .category-page {
    min-height: 100vh;
  }

  .header-hook-prose :global(p) {
    margin: 0.4rem 0;
  }
  .header-hook-prose :global(p:first-child) {
    margin-top: 0;
  }
  .header-hook-prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .hub-prose {
    font-size: 1.05rem;
    line-height: 2;
    color: #334155;
    max-width: 840px;
    margin: 0 auto;
  }
  .hub-prose :global(h1:first-child) {
    display: none;
  }
  .hub-prose :global(blockquote:first-child) {
    font-size: 1.15rem;
    font-style: normal;
    font-weight: 600;
    border-left: 4px solid #4a7c28;
    padding: 1rem 1.5rem;
    margin: 0 0 2rem 0;
    background: #f0f7ee;
    border-radius: 0 8px 8px 0;
    color: #1e3a5f;
    line-height: 1.9;
  }
  .hub-prose :global(blockquote) {
    border-left: 4px solid #4a7c28;
    background: linear-gradient(to right, rgba(26, 60, 52, 0.04), transparent);
    margin: 2.5rem 0;
    padding: 1.5rem 1.75rem;
    border-radius: 0 12px 12px 0;
    font-style: italic;
    color: #3a4f44;
    font-size: 1.05rem;
  }
  .hub-prose :global(blockquote p) {
    margin-bottom: 0;
  }
  .hub-prose :global(blockquote.callout-note) {
    border-left-color: #3b82f6;
    background: linear-gradient(to right, rgba(59, 130, 246, 0.06), transparent);
    font-style: normal;
  }
  .hub-prose :global(blockquote.callout-warning) {
    border-left-color: #f59e0b;
    background: linear-gradient(to right, rgba(245, 158, 11, 0.06), transparent);
    font-style: normal;
  }
  .hub-prose :global(blockquote.callout-tip) {
    border-left-color: #10b981;
    background: linear-gradient(to right, rgba(16, 185, 129, 0.06), transparent);
    font-style: normal;
  }
  .hub-prose :global(blockquote.callout-data) {
    border-left-color: #8b5cf6;
    background: linear-gradient(to right, rgba(139, 92, 246, 0.06), transparent);
    font-style: normal;
  }
  .hub-prose :global(blockquote.pull-quote) {
    border-left: none;
    background: none;
    text-align: center;
    font-size: 1.35rem;
    font-weight: 600;
    font-style: normal;
    color: #0e3a5c;
    padding: 2rem 2.5rem;
    margin: 3rem auto;
    max-width: 680px;
    line-height: 1.8;
    position: relative;
  }
  .hub-prose :global(blockquote.pull-quote)::before {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background: #4a7c28;
    margin: 0 auto 1.5rem;
    border-radius: 2px;
  }
  .hub-prose :global(blockquote.pull-quote)::after {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background: #4a7c28;
    margin: 1.5rem auto 0;
    border-radius: 2px;
  }
  .hub-prose :global(h2) {
    font-size: var(--title-subsection-size);
    font-weight: 800;
    margin: 4rem 0 1.2rem;
    color: #1a1a2e;
    padding-bottom: 0.6rem;
    border-bottom: 2px solid #e2e8f0;
    letter-spacing: var(--title-letter-spacing);
    line-height: var(--title-line-height);
    font-family: var(--font-editorial);
  }
  .hub-prose :global(h3) {
    font-size: var(--title-minor-size);
    font-weight: 700;
    margin: 3rem 0 0.75rem;
    color: #334155;
    line-height: 1.4;
    letter-spacing: 0.02em;
    font-family: var(--font-editorial);
  }
  .hub-prose :global(p) {
    margin: 1.1rem 0;
    text-align: justify;
    color: #2c2c2c;
  }
  .hub-prose :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
  }
  .hub-prose :global(ol) {
    list-style: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
  }
  .hub-prose :global(li) {
    margin-bottom: 0.3rem;
    line-height: 1.65;
  }
  .hub-prose :global(a) {
    color: #334155;
    text-decoration: none;
    border-bottom: 1.5px solid #94a3b8;
    padding-bottom: 1px;
    transition: all 0.2s;
  }
  .hub-prose :global(a:hover) {
    color: #1a1a2e;
