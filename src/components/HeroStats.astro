---
import placeConfig from '../../place.config';

const { stats } = placeConfig.home;
---

<div
  class="mt-16 grid grid-cols-4 gap-6 max-[768px]:mt-8 max-[768px]:grid-cols-2 max-[768px]:gap-3 max-[380px]:gap-2"
>
  {
    stats.map((stat) => (
      <div class="flex flex-col items-center justify-center rounded-xl border border-white/20 bg-white/10 px-4 py-6 text-center transition-all duration-300 hover:-translate-y-1 hover:border-white/30 hover:bg-white/15 max-[768px]:gap-[0.15rem] max-[768px]:rounded-[10px] max-[768px]:px-3 max-[768px]:py-4 max-[380px]:px-2 max-[380px]:py-3">
        <span class="mb-[0.3rem] block text-[1.8rem] leading-[1.4] max-[768px]:mb-[0.1rem] max-[768px]:text-[1.3rem]">
          {stat.icon}
        </span>
        <span class="mb-2 block whitespace-nowrap text-[2.2rem] font-bold leading-tight text-white max-[768px]:mb-[0.2rem] max-[768px]:text-[1.5rem] max-[380px]:text-[1.3rem]">
          {stat.number}
        </span>
        <span class="text-base font-medium tracking-[0.02em] text-white/80 max-[768px]:text-[0.8rem] max-[380px]:text-[0.75rem]">
          {stat.label}
        </span>
      </div>
    ))
  }
</div>
