---
/**
 * ArticleCard — shared article card component.
 *
 * Extracted from the v1 fork. Four density modes: premium, compact, row, detailed.
 */

export interface Props {
  href?: string;
  title: string;
  description?: string;
  categoryLabel?: string;
  categoryColor?: string;
  categoryIcon?: string;
  date?: string;
  readingTime?: string;
  footnotes?: number;
  tags?: string[];
  coverImage?: string;
  imageLoading?: 'eager' | 'lazy';
  density?: 'premium' | 'compact' | 'row' | 'detailed';
  imageSide?: 'left' | 'right';
  openIn?: 'new-tab' | 'same-tab';
  dataAttrs?: Record<string, string | undefined>;
}

const {
  href,
  title,
  description,
  categoryLabel,
  categoryColor = '#16a34a',
  categoryIcon,
  date,
  readingTime,
  footnotes,
  tags,
  coverImage,
  imageLoading = 'lazy',
  density = 'compact',
  imageSide = 'right',
  openIn = 'new-tab',
  dataAttrs = {},
} = Astro.props;

const target = openIn === 'new-tab' ? '_blank' : '_self';
const rel = openIn === 'new-tab' ? 'noopener noreferrer' : undefined;
const Tag = href ? 'a' : 'div';
const densityClass = `is-${density}`;
const imgSideClass =
  density === 'detailed' && imageSide === 'left' ? 'is-img-left' : '';
const classes = ['article-card', densityClass, imgSideClass, 'no-external-icon']
  .filter(Boolean)
  .join(' ');
---

<Tag
  class={classes}
  href={href}
  target={href ? target : undefined}
  rel={rel}
  {...dataAttrs}
>
  {
    density === 'premium' && (
      <div
        class="article-card-hero"
        style={
          coverImage
            ? `background-image: url('${coverImage}');`
            : `background: linear-gradient(135deg, ${categoryColor}22, ${categoryColor}44);`
        }
        aria-hidden="true"
      >
        {!coverImage && categoryIcon && (
          <span
            class="article-card-hero-icon"
            style={`color: ${categoryColor};`}
          >
            {categoryIcon}
          </span>
        )}
        {coverImage && <span class="article-card-hero-overlay" />}
      </div>
    )
  }
  {
    density === 'compact' && categoryColor && (
      <span
        class="article-card-dot"
        style={`background: ${categoryColor};`}
        aria-hidden="true"
      />
    )
  }
  {
    density === 'row' && categoryLabel && (
      <span
        class="article-card-pill"
        style={`color: ${categoryColor}; background: ${categoryColor}1f;`}
      >
        {categoryIcon ? `${categoryIcon} ${categoryLabel}` : categoryLabel}
      </span>
    )
  }

  <div class="article-card-body">
    {
      density === 'detailed' && (categoryLabel || date) && (
        <div class="article-card-toprow">
          {categoryLabel && (
            <span
              class="article-card-pill"
              style={`color: ${categoryColor}; background: ${categoryColor}1f;`}
            >
              {categoryIcon
                ? `${categoryIcon} ${categoryLabel}`
                : categoryLabel}
            </span>
          )}
          {date && <span class="article-card-updated">{date}</span>}
        </div>
      )
    }
    {
      density === 'premium' && (categoryLabel || date) && (
        <div class="article-card-premrow">
          {categoryLabel && (
            <span
              class="article-card-badge"
              style={`color: ${categoryColor}; background: ${categoryColor}14; border-color: ${categoryColor}28;`}
            >
              {categoryLabel}
            </span>
          )}
          {date && <span class="article-card-premdate">{date}</span>}
        </div>
      )
    }

    <h4 class="article-card-title">{title}</h4>

    {description && <p class="article-card-desc">{description}</p>}

    {
      (categoryLabel || readingTime) && density === 'compact' && (
        <span class="article-card-meta">
          {categoryLabel}
          {categoryLabel && readingTime && ' · '}
          {readingTime}
        </span>
      )
    }

    {
      density === 'premium' && (
        <span class="article-card-cta" style={`color: ${categoryColor};`}>
          <span class="article-card-cta-label">{readingTime || 'Read'}</span>
          <svg
            class="article-card-cta-arrow"
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </span>
      )
    }

    {
      density === 'detailed' &&
        ((tags && tags.length > 0) || !!footnotes || !!readingTime) && (
          <div class="article-card-foot">
            {tags && tags.length > 0 && (
              <span class="article-card-tags">
                {tags.slice(0, 3).map((tg) => (
                  <span class="article-card-tag">#{tg}</span>
                ))}
              </span>
            )}
            {(!!footnotes || !!readingTime) && (
              <span class="article-card-stats">
                {!!footnotes && (
                  <span class="article-card-stat" title="Citations">
                    <svg
                      width="13"
                      height="13"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                      <polyline points="14 2 14 8 20 8" />
                    </svg>
                    {footnotes}
                  </span>
                )}
                {!!readingTime && (
                  <span class="article-card-stat">
                    <svg
                      width="13"
                      height="13"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <circle cx="12" cy="12" r="10" />
                      <polyline points="12 6 12 12 16 14" />
                    </svg>
                    {readingTime}
                  </span>
                )}
              </span>
            )}
          </div>
        )
    }
  </div>

  {density === 'row' && date && <span class="article-card-date">{date}</span>}

  {
    density === 'detailed' &&
      (coverImage ? (
        <span class="article-card-thumbwrap">
          <img
            class="article-card-thumb"
            src={coverImage}
            alt=""
            loading={imageLoading}
            decoding="async"
          />
        </span>
      ) : (
        <span
          class="article-card-thumbwrap article-card-thumb-ph"
          style={`background: ${categoryColor}14;`}
          aria-hidden="true"
        >
          {categoryIcon}
        </span>
      ))
  }
</Tag>

<style is:global>
  .article-card {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 14px;
    margin: 6px 0;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    background: white;
    cursor: pointer;
    transition:
      transform 0.16s,
      border-color 0.16s,
      box-shadow 0.16s,
      background 0.16s;
    text-decoration: none;
    color: inherit;
    text-align: left;
    font-family: inherit;
    width: 100%;
    box-sizing: border-box;
  }
  .article-card:hover {
    border-color: #16a34a;
    background: #fafdf6;
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(22, 163, 74, 0.08);
  }
  .article-card-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .article-card-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #14532d;
    margin: 0;
    line-height: 1.35;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .article-card-desc {
    font-size: 0.78rem;
    color: #6b7280;
    line-height: 1.45;
    margin: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .article-card-meta {
    font-size: 0.7rem;
    color: #9ca3af;
    margin-top: 2px;
    font-weight: 500;
  }
  .article-card-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 6px;
  }
  .article-card-cta {
    font-size: 0.78rem;
    font-weight: 600;
    margin-top: 4px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: #16a34a;
  }

  /* Premium variant */
  .article-card.is-premium {
    flex-direction: column;
    align-items: stretch;
    padding: 0;
    overflow: hidden;
    gap: 0;
    border-radius: 16px;
    border-color: rgba(26, 60, 52, 0.07);
    box-shadow: 0 2px 12px rgba(26, 60, 52, 0.05);
    transition:
      transform 0.25s,
      box-shadow 0.25s;
  }
  .article-card.is-premium:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 40px rgba(26, 60, 52, 0.12);
    border-color: rgba(26, 60, 52, 0.07);
    background: white;
  }
  .article-card.is-premium .article-card-hero {
    position: relative;
    height: 160px;
    background-size: cover;
    background-position: center;
    background-color: #e8efec;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .article-card.is-premium .article-card-hero-icon {
    font-size: 2.8rem;
    line-height: 1;
    opacity: 0.75;
  }
  .article-card.is-premium .article-card-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(10, 22, 19, 0.35)
    );
  }
  .article-card.is-premium .article-card-body {
    padding: 20px 24px 24px;
    gap: 8px;
  }
  .article-card.is-premium .article-card-premrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
  }
  .article-card.is-premium .article-card-badge {
    display: inline-block;
    padding: 0.22rem 0.65rem;
    border-radius: 9999px;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    border: 1px solid transparent;
    margin: 0;
  }
  .article-card.is-premium .article-card-premdate {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.72rem;
    color: #94a3b8;
    font-variant-numeric: tabular-nums;
  }
  .article-card.is-premium .article-card-title {
    font-family: var(--font-editorial);
    font-size: 1rem;
    font-weight: 600;
    color: #0e3a5c;
    line-height: 1.45;
    -webkit-line-clamp: 2;
    transition: color 0.16s;
  }
  .article-card.is-premium:hover .article-card-title {
    color: #0369a1;
  }
  .article-card.is-premium .article-card-desc {
    font-size: 0.8rem;
    color: #7a8b7e;
    line-height: 1.5;
    -webkit-line-clamp: 4;
  }
  .article-card.is-premium .article-card-cta {
    margin-top: auto;
    padding-top: 4px;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  /* Row variant */
  .article-card.is-row {
    align-items: flex-start;
    gap: 12px;
    padding: 12px;
    margin: 0;
    border-color: transparent;
    background: transparent;
    border-radius: 8px;
  }
  .article-card.is-row:hover {
    border-color: #e2e8f0;
    background: #f8fafc;
    transform: none;
    box-shadow: none;
  }
  .article-card.is-row .article-card-pill {
    flex-shrink: 0;
    margin-top: 0.15rem;
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    padding: 0.18rem 0.55rem;
    font-size: 0.7rem;
    font-weight: 600;
    line-height: 1.3;
    white-space: nowrap;
  }
  .article-card.is-row .article-card-body {
    gap: 2px;
  }
  .article-card.is-row .article-card-title {
    font-family: var(--font-editorial);
    font-size: 1.02rem;
    font-weight: 600;
    color: #0e3a5c;
    line-height: 1.45;
    -webkit-line-clamp: 1;
    transition: color 0.16s;
  }
  .article-card.is-row:hover .article-card-title {
    color: #065f46;
  }
  .article-card.is-row .article-card-desc {
    font-size: 0.82rem;
    color: #94a3b8;
    line-height: 1.5;
    -webkit-line-clamp: 1;
    margin-top: 0.1rem;
  }
  .article-card.is-row .article-card-date {
    flex-shrink: 0;
    margin-top: 0.2rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.78rem;
    color: #94a3b8;
    font-variant-numeric: tabular-nums;
  }

  /* Detailed variant */
  .article-card.is-detailed {
    flex-direction: row;
    align-items: flex-start;
    gap: 16px;
    padding: 16px 18px;
    margin: 0;
    border-radius: 14px;
  }
  .article-card.is-detailed .article-card-thumbwrap {
    width: 200px;
    height: 125px;
    flex-shrink: 0;
    align-self: center;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid rgba(15, 23, 42, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f8fafc;
  }
  .article-card.is-detailed .article-card-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .article-card.is-detailed:hover .article-card-thumb {
    transform: scale(1.04);
  }
  .article-card.is-detailed .article-card-thumb-ph {
    font-size: 30px;
    opacity: 0.55;
  }
  .article-card.is-detailed.is-img-left .article-card-thumbwrap {
    order: -1;
  }
  @media (max-width: 768px) {
    .article-card.is-detailed {
      flex-direction: column;
    }
    .article-card.is-detailed .article-card-thumbwrap {
      order: -1;
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 10;
      align-self: stretch;
    }
    .article-card.is-detailed .article-card-thumb-ph {
      font-size: 36px;
    }
  }
  .article-card.is-detailed .article-card-body {
    gap: 8px;
  }
  .article-card.is-detailed .article-card-toprow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .article-card.is-detailed .article-card-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    padding: 0.2rem 0.6rem;
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1.3;
    white-space: nowrap;
  }
  .article-card.is-detailed .article-card-updated {
    flex-shrink: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.76rem;
    color: #94a3b8;
    font-variant-numeric: tabular-nums;
  }
  .article-card.is-detailed .article-card-title {
    font-family: var(--font-editorial);
    font-size: 1.12rem;
    font-weight: 700;
    color: #0e3a5c;
    line-height: 1.4;
    -webkit-line-clamp: 2;
    transition: color 0.16s;
  }
  .article-card.is-detailed:hover .article-card-title {
    color: #065f46;
  }
  .article-card.is-detailed .article-card-desc {
    font-size: 0.9rem;
    color: #64748b;
    line-height: 1.6;
    display: block;
    -webkit-line-clamp: unset;
    overflow: visible;
  }
  .article-card.is-detailed .article-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 4px;
    padding-top: 12px;
    border-top: 1px solid #f1f5f9;
  }
  .article-card.is-detailed .article-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    min-width: 0;
  }
  .article-card.is-detailed .article-card-tag {
    font-size: 0.74rem;
    font-weight: 500;
    color: #64748b;
    white-space: nowrap;
  }
  .article-card.is-detailed .article-card-stats {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .article-card.is-detailed .article-card-stat {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.76rem;
    color: #94a3b8;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .article-card.is-detailed .article-card-stat svg {
    opacity: 0.8;
  }
</style>
