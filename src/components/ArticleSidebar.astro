---
import placeConfig from '../../place.config';

interface Props {
  title: string;
  tags?: string[];
  readingTime?: number;
  date?: string;
  contributors?: string[];
  commitHash?: string;
  category: string;
  categoryName: string;
  categoryColor: string;
  slug: string;
  relatedArticles?: Array<{ title: string; slug: string; category: string }>;
}

const {
  title,
  tags = [],
  readingTime,
  date,
  contributors = [],
  commitHash = '',
  category,
  categoryColor,
  slug,
  relatedArticles = [],
} = Astro.props;

const { domain } = placeConfig.place;
const { links } = placeConfig;
const articleUrl = `https://${domain}/${category}/${slug}`;
const encodedUrl = encodeURIComponent(articleUrl);
const encodedTitle = encodeURIComponent(title);
const shortHash = commitHash ? commitHash.substring(0, 7) : '';

const displayDate = date
  ? new Date(date).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const readingTimeLabel = readingTime != null ? `${readingTime} min read` : '';
---

<aside class="sticky top-24 flex flex-col">
  <!-- Reading meta -->
  <div
    class="border-b border-[rgba(26,60,52,0.08)] pb-5 [&_.meta-row]:mb-2 [&_.meta-row]:flex [&_.meta-row]:items-center [&_.meta-row]:gap-[0.55rem] [&_.meta-row]:font-['Inter',system-ui,sans-serif] [&_.meta-row]:text-[0.82rem] [&_.meta-row]:text-[#4a5e52] [&_.meta-row_svg]:flex-shrink-0 [&_.meta-row_svg]:text-[#7a8b7e]"
  >
    {
      readingTime && (
        <div class="meta-row">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <>
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </>
          </svg>
          <span>{readingTimeLabel}</span>
        </div>
      )
    }
    {
      displayDate && (
        <div class="meta-row">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <>
              <rect x="3" y="4" width="18" height="18" rx="2" />
              <line x1="16" y1="2" x2="16" y2="6" />
              <line x1="8" y1="2" x2="8" y2="6" />
              <line x1="3" y1="10" x2="21" y2="10" />
            </>
          </svg>
          <span>{displayDate}</span>
        </div>
      )
    }
  </div>

  <!-- Tags -->
  {
    tags.length > 0 && (
      <div class="border-b border-[rgba(26,60,52,0.08)] py-5">
        <p class="mb-[0.85rem] font-['Inter',system-ui,sans-serif] text-[0.67rem] font-bold uppercase tracking-[0.2em] text-[#9aa89e]">
          Keywords
        </p>
        <div class="flex flex-wrap gap-[0.4rem]">
          {tags.map((tag) => (
            <span
              class="rounded-full border border-solid px-[0.65rem] py-[0.28rem] font-['Inter',system-ui,sans-serif] text-[0.75rem] font-medium"
              style={`color: ${categoryColor}; background: ${categoryColor}12; border-color: ${categoryColor}28;`}
            >
              {tag}
            </span>
          ))}
        </div>
      </div>
    )
  }

  <!-- Share -->
  <div class="border-b border-[rgba(26,60,52,0.08)] py-5 last:border-b-0">
    <p
      class="mb-[0.85rem] font-['Inter',system-ui,sans-serif] text-[0.67rem] font-bold uppercase tracking-[0.2em] text-[#9aa89e]"
    >
      Share
    </p>
    <div
      class="flex flex-col gap-[0.1rem] [&_.share-row]:flex [&_.share-row]:w-full [&_.share-row]:cursor-pointer [&_.share-row]:items-center [&_.share-row]:gap-[0.65rem] [&_.share-row]:rounded-md [&_.share-row]:border-none [&_.share-row]:bg-transparent [&_.share-row]:px-2 [&_.share-row]:py-[0.45rem] [&_.share-row]:text-left [&_.share-row]:font-['Inter',system-ui,sans-serif] [&_.share-row]:text-[0.82rem] [&_.share-row]:text-[#4a5e52] [&_.share-row]:no-underline [&_.share-row]:transition-colors [&_.share-row]:duration-150 [&_.share-row_svg]:flex-shrink-0 [&_.share-row_svg]:text-[#7a8b7e] [&_.share-row:hover]:bg-[rgba(26,60,52,0.05)] [&_.share-row:hover]:text-[#0e3a5c] [&_.share-row:hover_svg]:text-[#0e3a5c]"
    >
      <a
        href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
        target="_blank"
        rel="noopener noreferrer"
        class="share-row no-external-icon"
        aria-label="Share on X"
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          ><path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.256 5.636L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117z"
          ></path></svg
        >
        <span>Share on X</span>
      </a>
      <a
        href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
        target="_blank"
        rel="noopener noreferrer"
        class="share-row no-external-icon"
        aria-label="Share on Facebook"
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          ><path
            d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"
          ></path></svg
        >
        <span>Share on Facebook</span>
      </a>
      <button
        class="share-row copy-link-btn"
        type="button"
        aria-label="Copy link"
        data-copy-default="Copy link"
        data-copy-copied="Copied!"
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
          ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
          ></path><path
            d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
          ></path></svg
        >
        <span class="copy-link-text">Copy link</span>
      </button>
    </div>
  </div>

  <!-- Commit -->
  {
    commitHash && (
      <div class="border-b border-[rgba(26,60,52,0.08)] py-5 last:border-b-0">
        <div class="flex items-center gap-[0.55rem] font-['Inter',system-ui,sans-serif] text-[0.82rem] text-[#7a8b7e]">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <><circle cx="12" cy="12" r="3" /><line x1="3" y1="12" x2="9" y2="12" /><line x1="15" y1="12" x2="21" y2="12" /></>
          </svg>
          <a
            href={`${links.repo}/commit/${commitHash}`}
            target="_blank"
            rel="noopener noreferrer"
            class="no-external-icon text-inherit no-underline transition-colors duration-150 hover:text-[#0e3a5c] hover:underline"
          >
            Commit {shortHash}
          </a>
        </div>
      </div>
    )
  }

  <!-- Contributors -->
  {
    contributors.length > 0 && (
      <div class="border-b border-[rgba(26,60,52,0.08)] py-5 last:border-b-0">
        <p class="mb-[0.85rem] font-['Inter',system-ui,sans-serif] text-[0.67rem] font-bold uppercase tracking-[0.2em] text-[#9aa89e]">
          Contributors
        </p>
        <div class="flex flex-wrap gap-[0.4rem]">
          {contributors.map((name) => (
            <span class="rounded-full border border-[rgba(0,109,119,0.15)] bg-[rgba(0,109,119,0.07)] px-[0.6rem] py-[0.22rem] font-['Inter',system-ui,sans-serif] text-[0.75rem] text-[#0369a1]">
              {name}
            </span>
          ))}
        </div>
      </div>
    )
  }

  <!-- Related articles (empty-safe: renders nothing until 1.3 populates data) -->
  {
    relatedArticles.length > 0 && (
      <div class="py-5">
        <p class="mb-[0.85rem] font-['Inter',system-ui,sans-serif] text-[0.67rem] font-bold uppercase tracking-[0.2em] text-[#9aa89e]">
          Related
        </p>
        <div class="flex flex-col gap-2">
          {relatedArticles.map((article) => (
            <a
              href={`/${article.category}/${article.slug}`}
              class="rounded-md px-2 py-[0.4rem] font-['Inter',system-ui,sans-serif] text-[0.82rem] text-[#4a5e52] no-underline transition-colors duration-150 hover:bg-[rgba(26,60,52,0.05)] hover:text-[#0e3a5c]"
            >
              {article.title}
            </a>
          ))}
        </div>
      </div>
    )
  }
</aside>

<script>
  (function () {
    const btn = document.querySelector<HTMLButtonElement>('.copy-link-btn');
    if (!btn) return;
    const textEl = btn.querySelector<HTMLSpanElement>('.copy-link-text');
    const defaultLabel = btn.dataset.copyDefault ?? 'Copy link';
    const copiedLabel = btn.dataset.copyCopied ?? 'Copied!';
    btn.addEventListener('click', () => {
      navigator.clipboard
        .writeText(window.location.href)
        .then(() => {
          if (textEl) textEl.textContent = copiedLabel;
          btn.style.color = '#006D77';
          setTimeout(() => {
            if (textEl) textEl.textContent = defaultLabel;
            btn.style.color = '';
          }, 2200);
        })
        .catch(() => {
          const ta = document.createElement('textarea');
          ta.value = window.location.href;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          if (textEl) textEl.textContent = copiedLabel;
          setTimeout(() => {
            if (textEl) textEl.textContent = defaultLabel;
          }, 2200);
        });
    });
  })();
</script>
