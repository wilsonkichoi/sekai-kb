---
import placeConfig from '../../place.config';
import * as fs from 'node:fs';
import * as path from 'node:path';

const { categories } = placeConfig;

const GRADIENTS: Record<string, string> = {
  history: 'linear-gradient(135deg, #92400e, #d97706)',
  'art-galleries': 'linear-gradient(135deg, #be185d, #ec4899)',
  'nature-marine-life': 'linear-gradient(135deg, #0e7490, #06b6d4)',
  food: 'linear-gradient(135deg, #ea580c, #f97316)',
  beaches: 'linear-gradient(135deg, #0284c7, #38bdf8)',
  trails: 'linear-gradient(135deg, #15803d, #22c55e)',
  'events-festivals': 'linear-gradient(135deg, #7c3aed, #a855f7)',
  neighborhoods: 'linear-gradient(135deg, #b45309, #f59e0b)',
};

function countArticles(slug: string, title: string): number {
  const dirPath = path.join(process.cwd(), 'knowledge', title);
  try {
    const files = fs.readdirSync(dirPath);
    return files.filter((f: string) => f.endsWith('.md') && !f.startsWith('_'))
      .length;
  } catch {
    return 0;
  }
}

const items = categories.map((c) => ({
  ...c,
  gradient: GRADIENTS[c.slug] || 'linear-gradient(135deg, #475569, #64748b)',
  count: countArticles(c.slug, c.title),
}));
---

<section
  class="mx-auto my-12 max-w-[var(--container-wide)] columns-3 gap-x-6 px-[clamp(1.5rem,5vw,5rem)] max-lg:columns-2 max-[768px]:mx-4 max-[768px]:my-8 max-[768px]:columns-1"
  aria-label="Category grid"
>
  {
    items.map((category) => (
      <article class="mb-6 flex break-inside-avoid">
        <a
          href={`/${category.slug}`}
          class="group relative flex w-full flex-col overflow-hidden rounded-3xl border border-[rgba(226,232,240,0.9)] bg-white/[0.98] text-inherit no-underline shadow-[0_12px_30px_rgba(15,23,42,0.06)] transition-all duration-[280ms] ease hover:-translate-y-1.5 hover:border-[rgba(148,163,184,0.5)] hover:shadow-[0_24px_50px_rgba(15,23,42,0.18),0_8px_16px_rgba(0,0,0,0.06)] max-[768px]:min-h-[272px]"
        >
          <div
            class="absolute inset-0 z-0 opacity-100 transition-opacity duration-[280ms] [mask-image:linear-gradient(to_bottom,rgba(0,0,0,0.15)_0%,rgba(0,0,0,0)_70%)] [-webkit-mask-image:linear-gradient(to_bottom,rgba(0,0,0,0.15)_0%,rgba(0,0,0,0)_70%)] group-hover:opacity-[0.35]"
            style={`background: ${category.gradient};`}
          />
          <div
            class="relative z-[1] flex h-[160px] flex-shrink-0 items-center justify-center overflow-hidden max-[768px]:!h-28"
          >
            <div class="relative z-[2] text-[3.25rem] transition-transform duration-[280ms] ease [filter:drop-shadow(0_4px_8px_rgba(0,0,0,0.15))] group-hover:scale-[1.04] max-[768px]:text-[2.8rem]">
              {category.icon}
            </div>
          </div>
          <div class="relative z-[1] flex flex-1 flex-col px-[1.35rem] pb-5 pt-[1.35rem]">
            <div class="mb-2 flex items-baseline justify-between gap-2">
              <h3 class="mb-[0.6rem] font-serif text-[1.6rem] font-extrabold leading-tight -tracking-[0.02em] text-[#0e3a5c] transition-colors duration-[250ms] ease group-hover:text-[#0369a1] max-[768px]:text-[1.2rem]">
                {category.title}
              </h3>
              <span class="flex flex-shrink-0 items-baseline gap-[0.2rem]">
                <span class="font-serif text-[1.1rem] font-semibold leading-none -tracking-[0.01em] text-[#a8634a] max-[768px]:text-[1.6rem]">
                  {category.count}
                </span>{' '}
                <span class="font-sans text-[0.7rem] font-medium tracking-[0.03em] text-[#a8634a]">
                  {category.count > 1 ? 'articles' : 'article'}
                </span>
              </span>
            </div>
            <p class="mb-[1.1rem] line-clamp-3 flex-1 text-[0.93rem] leading-relaxed text-[#475569] max-[768px]:text-[0.9rem]">
              {category.description}
            </p>
            <div class="mt-auto flex justify-start">
              <span class="flex items-center gap-1 text-[0.875rem] font-semibold text-[#0369a1] transition-colors duration-200 ease group-hover:text-[#1d4ed8]">
                Explore
                <span class="inline-block transition-transform duration-[250ms] [transition-timing-function:cubic-bezier(0.34,1.56,0.64,1)] group-hover:translate-x-1">
                  &rarr;
                </span>
              </span>
            </div>
          </div>
        </a>
      </article>
    ))
  }
</section>
