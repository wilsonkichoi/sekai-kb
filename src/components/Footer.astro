---
/**
 * Footer.astro — site footer.
 *
 * Genericized (task 1.1a): brand, tagline, category links, GitHub repo, contact
 * email, and social handles all read from `place.config`. Category links are
 * generated from `place.config.categories`; social links render only when
 * `features.social` is true; Graph/Dashboard links gate on their feature flags.
 * No place literals.
 */
import { useTranslations, getLangFromUrl } from '../i18n/utils';
import placeConfig from '../../place.config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { name, tagline, domain } = placeConfig.place;
const { categories, features, links } = placeConfig;
const domainDot = `.${domain.split('.').pop()}`;
const year = new Date().getFullYear();

// Build social links from handles (stored with a leading `@`).
const bare = (h: string) => h.replace(/^@/, '');
const social: Array<{ href: string; label: string }> = [];
if (features.social && links.social.twitter) {
  social.push({
    href: `https://x.com/${bare(links.social.twitter)}`,
    label: `𝕏 ${links.social.twitter}`,
  });
}
if (features.social && links.social.threads) {
  social.push({
    href: `https://www.threads.com/@${bare(links.social.threads)}`,
    label: `Threads ${links.social.threads}`,
  });
}
if (features.social && links.social.instagram) {
  social.push({
    href: `https://www.instagram.com/${bare(links.social.instagram)}`,
    label: `IG ${links.social.instagram}`,
  });
}

const colLinkClass =
  "flex flex-col gap-[0.4rem] [&>a]:relative [&>a]:py-1 [&>a]:text-[0.85rem] [&>a]:text-[#94a3b8] [&>a]:no-underline [&>a]:transition-all [&>a]:duration-200 [&>a]:ease [&>a:hover]:text-[#e2e8f0] [&>a:hover]:after:absolute [&>a:hover]:after:bottom-0 [&>a:hover]:after:left-0 [&>a:hover]:after:right-0 [&>a:hover]:after:h-px [&>a:hover]:after:bg-[#7ab8d4] [&>a:hover]:after:opacity-70 [&>a:hover]:after:content-['']";
---

<footer
  role="contentinfo"
  class="bg-[#0c2d4a] px-0 pb-6 pt-12 text-[#94a3b8] max-[768px]:pb-5 max-[768px]:pt-10"
>
  <div
    class="mx-auto max-w-[var(--container-wide)] px-[var(--space-page-x)] max-[768px]:px-5"
  >
    <div
      class="mb-8 grid grid-cols-[2fr_1fr_1fr_1fr] gap-8 max-[768px]:grid-cols-2 max-[768px]:gap-7 max-[480px]:grid-cols-1"
    >
      <div class="max-[768px]:col-span-full">
        <span class="mb-2 block text-[1.2rem] font-bold text-white"
          >{name}<span class="text-[#38bdf8]">{domainDot}</span></span
        >
        <p>{tagline}</p>
        <p class="mt-2 text-[#22c55e]">{t('footer.builtWith')}</p>
        <p class="mt-3">
          <a
            href="https://creativecommons.org/licenses/by-sa/4.0/deed.en"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center text-[0.8rem] text-[#7ab8d4] no-underline transition-all duration-200 ease hover:text-[#c7d2c7]"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 496 512"
              fill="currentColor"
              class="mr-1.5"
            >
              <path
                d="M245.83 214.87l-33.22 17.28c-9.43-19.58-25.24-19.93-27.46-19.93-22.13 0-33.22 14.61-33.22 43.84 0 23.57 9.21 43.84 33.22 43.84 14.47 0 24.65-7.09 30.57-21.26l30.55 15.5c-6.17 11.51-25.69 38.98-65.1 38.98-22.6 0-73.96-10.32-73.96-77.05 0-58.69 43-77.06 72.63-77.06 30.72-.01 52.7 11.95 65.99 35.86zm143.05 0l-32.78 17.28c-9.5-19.77-25.72-19.93-27.9-19.93-22.14 0-33.22 14.61-33.22 43.84 0 23.55 9.23 43.84 33.22 43.84 14.45 0 24.65-7.09 30.54-21.26l31.04 15.5c-6.17 11.51-25.69 38.98-65.09 38.98-22.69 0-73.96-9.87-73.96-77.05 0-58.67 42.97-77.06 72.6-77.06 30.71-.01 52.58 11.95 65.55 35.86zM247.56 8.05C104.74 8.05 0 123.11 0 256.05c0 138.49 113.6 248 247.56 248 129.93 0 248.44-100.87 248.44-248 0-137.87-106.62-248-248.44-248zm.87 450.81c-112.54 0-203.7-93.04-203.7-202.81 0-105.42 85.43-203.27 203.72-203.27 112.53 0 202.82 89.46 202.82 203.26-.01 121.69-99.68 202.82-202.84 202.82z"
              ></path>
            </svg>
            CC BY-SA 4.0
          </a>
        </p>
        <p class="mt-[0.6rem] flex items-center gap-[0.4rem] text-[0.8rem]">
          <span class="text-[#94a3b8]">{t('footer.support')}:</span>
          <a
            href={links.repo}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded bg-white/[0.06] px-2 py-[0.15rem] text-[0.8rem] tracking-[0.02em] text-[#7ab8d4] no-underline transition-all duration-200 ease hover:bg-white/[0.12] hover:text-[#c7d2c7]"
            >{t('footer.support.cta')} →</a
          >
        </p>
      </div>

      <div class={colLinkClass}>
        <h4 class="mb-1 text-[0.85rem] uppercase tracking-[0.05em] text-white">
          {t('footer.explore')}
        </h4>
        <a href="/latest">🆕 {t('nav.latest')}</a>
        {
          categories.map((category) => (
            <a href={`/${category.slug}`}>
              {category.icon} {category.title}
            </a>
          ))
        }
      </div>

      <div class={colLinkClass}>
        <h4 class="mb-1 text-[0.85rem] uppercase tracking-[0.05em] text-white">
          {t('footer.project')}
        </h4>
        <a href={links.repo} target="_blank" rel="noopener">GitHub</a>
        <a href="/about">{t('footer.about')}</a>
        {features.graph && <a href="/graph">{t('footer.graph')}</a>}
        {features.dashboard && <a href="/dashboard">{t('footer.dashboard')}</a>}
        <a href={`${links.repo}/blob/main/CONTRIBUTING.md`} target="_blank" rel="noopener"
          >{t('footer.contribute')}</a
        >
        <a href="/changelog">{t('footer.changelog')}</a>
        <a href="/rss.xml">{t('footer.rss')}</a>
      </div>

      <div class={colLinkClass}>
        <h4 class="mb-1 text-[0.85rem] uppercase tracking-[0.05em] text-white">
          {t('footer.contact')}
        </h4>
        {
          social.map((s) => (
            <a href={s.href} target="_blank" rel="noopener">
              {s.label}
            </a>
          ))
        }
        <a href={`mailto:${links.email}`}>{links.email}</a>
        <a href={`${links.repo}/issues`} target="_blank" rel="noopener"
          >{t('footer.report')}</a
        >
        <a href={`${links.repo}/discussions`} target="_blank" rel="noopener"
          >{t('footer.discuss')}</a
        >
      </div>
    </div>
    <div class="border-t border-[#1e293b] pt-6 text-center text-[0.8rem]">
      &copy; {year} {name}{domainDot} — {tagline}
    </div>
  </div>
</footer>
