# derived content (SSOT is knowledge/; written by scripts/core/sync.sh)
src/content/

# generated build artifacts (regenerated by the prebuild chain; must not enter git)
# — public/kb/*: the /kb/ AI-consumer endpoints + search indexes (build-kb-index, build-search-index)
# — public/llms.txt: the llms.txt boot file (build-kb-index)
# — src/data/*: build-time-import JSON (content-dates, git-info, latest, related)
public/kb/
public/llms.txt
src/data/

# visual regression (baseline PNGs are large; commit only the manifest)
reports/visual/baseline/*.png
reports/visual/current/
reports/visual/diff/
reports/visual/diff-report.html
reports/visual/diff-summary.json

